{
  "name": "pdf-squeezer",
  "version": "0.1.1",
  "description": "A lightweight PDF compression tool built with Electron and Vue 3, using Ghostscript for high-quality PDF compression.",
  "private": true,
  "type": "module",
  "main": "electron/main.ts",
  "scripts": {
    "dev": "cross-env NODE_ENV=development concurrently \"npm run vue:dev\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "npm run vue:build && electron-builder",
    "vue:dev": "vite",
    "vue:build": "vite build"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "element-plus": "^2.13.4",
    "pdf-lib": "^1.17.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3",
    "vuedraggable": "^4.1.0",
    "wait-on": "^9.0.4"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.3.5",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/tsconfig": "^0.8.1",
    "electron": "^40.8.0",
    "electron-builder": "23.6.0",
    "npm-run-all2": "^8.0.4",
    "sass": "^1.97.3",
    "typescript": "~5.9.3",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "build": {
    "appId": "com.example.vue-electron",
    "productName": "Pdf Squeezer",
    "directories": {
      "buildResources": "assets",
      "output": "electron-dist"
    },
    "extraResources": [
      {
        "from": "dist/",
        "to": "vue/"
      },
      {
        "from": "core/",
        "to": "core/"
      }
    ],
    "asar": true,
    "win": {
      "target": "nsis",
      "icon": "./electron/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "./electron/icon.ico",
      "uninstallerIcon": "./electron/icon.ico",
      "installerHeaderIcon": "./electron/icon.ico"
    }
  }
}